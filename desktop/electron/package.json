{
  "name": "nion-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Nion desktop shell (Electron)",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "pnpm run build && electron dist/main.js",
    "start": "pnpm run build && electron dist/main.js",
    "dist": "pnpm run build && electron-builder --config electron-builder.yml"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12",
    "typescript": "^5.9.2"
  },
  "packageManager": "pnpm@10.26.2"
}
